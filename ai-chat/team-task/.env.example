# Server
PORT=3001
HOST=0.0.0.0

# Storage
DATA_FILE=data/tasks.jsonl

# ai-chat integration (optional)
# Set CHAT_URL to enable push notifications to your ai-chat instance
CHAT_URL=http://localhost:3000
CHAT_SENDER_ID=task-manager
CHAT_DISPLAY_NAME=Task Manager
CHAT_CHANNEL=general

# Auto-notify ai-chat on task status changes
NOTIFY_ON_CHANGE=false
