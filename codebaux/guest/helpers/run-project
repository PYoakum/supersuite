#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# run-project
# Executes the project entrypoint inside /workspace, captures
# stdout/stderr, and reports results via the serial protocol.
#
# Called by serial-listener when HOST_RUN is received.
#
# Protocol:
#   Output: GUEST_RUN_START  (immediately)
#           GUEST_LOG:<line> (per output line)
#           GUEST_PREVIEW_FILE:<path> (if output artifact found)
#           GUEST_RUN_OK or GUEST_RUN_FAIL:<code>
# ─────────────────────────────────────────────────────────────
set -uo pipefail

. /etc/codebaux/protocol.conf

# ─── Stop any lingering process ───
/usr/local/bin/stop-project 2>/dev/null || true

# ─── Signal start ───
emit "${GUEST_RUN_START}"

# ─── Determine entrypoint ───
entrypoint="${DEFAULT_ENTRYPOINT}"

# Check for package.json "main" field
if [[ -f "${WORKSPACE}/package.json" ]]; then
    pkg_main=$(node -e "
        try {
            const p = require('${WORKSPACE}/package.json');
            if (p.main) console.log(p.main);
            else if (p.scripts && p.scripts.start) {
                const m = p.scripts.start.match(/node\s+(\S+)/);
                if (m) console.log(m[1]);
            }
        } catch(e) {}
    " 2>/dev/null)
    if [[ -n "${pkg_main}" ]]; then
        entrypoint="${pkg_main}"
        log_and_emit "${GUEST_LOG}[run] using entrypoint from package.json: ${entrypoint}"
    fi
fi

# ─── Validate entrypoint exists ───
entrypoint_path="${WORKSPACE}/${entrypoint}"
if [[ ! -f "${entrypoint_path}" ]]; then
    log_and_emit "${GUEST_LOG}[error] entrypoint not found: ${entrypoint_path}"
    emit "${GUEST_RUN_FAIL}entrypoint not found: ${entrypoint}"
    exit 1
fi

log_and_emit "${GUEST_LOG}[run] executing: node ${entrypoint_path}"

# ─── Clear old output ───
rm -f "${WORKSPACE_OUT}/index.html" 2>/dev/null || true

# ─── Execute ───
# Run node in the workspace directory, streaming output line-by-line.
# Use a FIFO so we can capture the PID and stream output simultaneously.
cd "${WORKSPACE}"

OUTPUT_FIFO="/tmp/project-output.$$"
mkfifo "${OUTPUT_FIFO}"
trap 'rm -f "${OUTPUT_FIFO}"' EXIT

node "${entrypoint_path}" > "${OUTPUT_FIFO}" 2>&1 &
NODE_PID=$!

# Write PID for stop-project
echo "${NODE_PID}" > "${PID_FILE}"

log_and_emit "${GUEST_LOG}[run] process started (PID ${NODE_PID})"

# ─── Stream output ───
# Read from the FIFO line-by-line and emit each line to the host.
while IFS= read -r line; do
    emit "${GUEST_LOG}${line}"
done < "${OUTPUT_FIFO}"

# Wait for the node process and capture its exit code
wait "${NODE_PID}" 2>/dev/null
exit_code=$?

# ─── Clean up PID file ───
rm -f "${PID_FILE}" 2>/dev/null || true

# ─── Check results ───
if [[ ${exit_code} -eq 0 ]]; then
    # Check for preview artifact
    if [[ -f "${WORKSPACE_OUT}/index.html" ]]; then
        log_and_emit "${GUEST_PREVIEW_FILE}${WORKSPACE_OUT}/index.html"
        log_and_emit "${GUEST_LOG}[run] preview artifact generated"
    else
        log_and_emit "${GUEST_LOG}[run] completed (no preview artifact)"
    fi
    emit "${GUEST_RUN_OK}"
else
    log_and_emit "${GUEST_LOG}[error] process exited with code ${exit_code}"
    emit "${GUEST_RUN_FAIL}${exit_code}"
fi

exit ${exit_code}
