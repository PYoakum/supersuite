#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# serial-listener
# Main control loop for the guest. Reads commands from the host
# via the serial port and dispatches to helper scripts.
#
# Started by the codebaux-serial OpenRC service on boot.
# Emits GUEST_READY once initialization is complete.
#
# Protocol (host → guest):
#   HOST_PING           → respond GUEST_READY
#   HOST_SYNC_BEGIN     → pipe lines to receive-project
#   HOST_SYNC_CHUNK:*   → (handled inside receive-project)
#   HOST_SYNC_END       → (handled inside receive-project)
#   HOST_RUN            → invoke run-project
#   HOST_STOP           → invoke stop-project
# ─────────────────────────────────────────────────────────────
set -uo pipefail

. /etc/codebaux/protocol.conf

# ─── Ensure workspace exists ───
mkdir -p "${WORKSPACE}" "${WORKSPACE_OUT}"

# ─── Signal readiness ───
echo "[serial-listener] started, PID $$" >> "${PROJECT_LOG}"
emit "${GUEST_READY}"

# ─── Main loop ───
# Read from serial device line-by-line.
# stty: set raw mode, no echo, correct baud rate.
stty -F "${SERIAL_DEV}" 115200 raw -echo -echoe -echok 2>/dev/null || true

while IFS= read -r line; do
    # Strip carriage returns
    line="${line%$'\r'}"

    # Skip empty lines
    [[ -z "${line}" ]] && continue

    echo "[$(date '+%H:%M:%S')] recv: ${line:0:60}" >> "${PROJECT_LOG}"

    case "${line}" in
        "${HOST_PING}")
            emit "${GUEST_READY}"
            ;;

        "${HOST_SYNC_BEGIN}")
            log_and_emit "${GUEST_LOG}[sync] HOST_SYNC_BEGIN received"
            # Pipe subsequent lines to receive-project.
            # receive-project reads from stdin until HOST_SYNC_END.
            /usr/local/bin/receive-project
            ;;

        "${HOST_RUN}")
            log_and_emit "${GUEST_LOG}[run] HOST_RUN received"
            # Run in background so the listener remains responsive
            /usr/local/bin/run-project &
            ;;

        "${HOST_STOP}")
            log_and_emit "${GUEST_LOG}[stop] HOST_STOP received"
            /usr/local/bin/stop-project
            ;;

        *)
            # Unknown command — log and ignore
            echo "[$(date '+%H:%M:%S')] unknown command: ${line:0:80}" >> "${PROJECT_LOG}"
            ;;
    esac

done < "${SERIAL_DEV}"

# If we exit the read loop, the serial device was lost. Log and exit.
echo "[serial-listener] serial device lost, exiting" >> "${PROJECT_LOG}"
exit 1
