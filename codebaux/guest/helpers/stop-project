#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# stop-project
# Terminates any running project process tracked by PID file.
#
# Called by serial-listener on HOST_STOP, and by run-project
# before starting a new execution.
#
# Strategy: SIGTERM → wait 2s → SIGKILL if still alive.
# ─────────────────────────────────────────────────────────────
set -uo pipefail

. /etc/codebaux/protocol.conf

if [[ ! -f "${PID_FILE}" ]]; then
    log_and_emit "${GUEST_LOG}[stop] no process tracked (${PID_FILE} not found)"
    exit 0
fi

pid=$(cat "${PID_FILE}" 2>/dev/null)

if [[ -z "${pid}" ]]; then
    log_and_emit "${GUEST_LOG}[stop] PID file empty, cleaning up"
    rm -f "${PID_FILE}"
    exit 0
fi

# Check if process is still running
if ! kill -0 "${pid}" 2>/dev/null; then
    log_and_emit "${GUEST_LOG}[stop] process ${pid} already exited"
    rm -f "${PID_FILE}"
    exit 0
fi

# ─── Graceful termination ───
log_and_emit "${GUEST_LOG}[stop] sending SIGTERM to ${pid}"
kill -TERM "${pid}" 2>/dev/null

# Wait up to 2 seconds for graceful exit
for i in $(seq 1 20); do
    if ! kill -0 "${pid}" 2>/dev/null; then
        log_and_emit "${GUEST_LOG}[stop] process ${pid} terminated gracefully"
        rm -f "${PID_FILE}"
        exit 0
    fi
    sleep 0.1
done

# ─── Force kill ───
log_and_emit "${GUEST_LOG}[stop] process ${pid} did not exit, sending SIGKILL"
kill -KILL "${pid}" 2>/dev/null
sleep 0.2

if ! kill -0 "${pid}" 2>/dev/null; then
    log_and_emit "${GUEST_LOG}[stop] process ${pid} killed"
else
    log_and_emit "${GUEST_LOG}[stop] WARNING: process ${pid} could not be killed"
fi

rm -f "${PID_FILE}"
exit 0
