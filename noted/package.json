    "test:auth": "node test-auth-e2e.js",
    "test:docs": "node test-docs-e2e.js",
    "test:versions": "node test-versions-e2e.js",
    "test:parser": "node test-parser-unit.js",
    "test:editor": "node test-editor-unit.js",
    "test:media": "node test-media-e2e.js",
    "test:search": "node test-search-e2e.js",
    "test:organize": "node test-organize-e2e.js"
  }
