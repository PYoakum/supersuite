[server]
port = 3000
host = "0.0.0.0"

[imap]
host = "imap.example.com"
port = 993
secure = true
user = "you@example.com"
password = "your-password"
page_size = 50

[smtp]
host = "smtp.example.com"
port = 587
secure = false
user = "you@example.com"
password = "your-password"
from_name = "Your Name"
from_address = "you@example.com"

[attachments]
max_upload_size = 26214400  # 25 MB

