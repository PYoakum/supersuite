#!/bin/sh
# save-workspace: Package workspace into /mnt/9p/export/workspace.tar
# This script runs inside the VM guest.

WORKSPACE="${1:-/root}"
MOUNTPOINT="/mnt"
EXPORT_DIR="$MOUNTPOINT/export"
ARTIFACT="$EXPORT_DIR/workspace.tar"
MANIFEST="$EXPORT_DIR/manifest.json"

# Check 9p mount
if ! mountpoint -q "$MOUNTPOINT" 2>/dev/null; then
  echo "9p filesystem not mounted. Mounting..."
  mkdir -p "$MOUNTPOINT"
  mount -t 9p -o trans=virtio,version=9p2000.L host9p "$MOUNTPOINT"
  if [ $? -ne 0 ]; then
    echo "ERROR: Failed to mount 9p filesystem."
    echo "Make sure the VM was started with filesystem support."
    exit 1
  fi
fi

mkdir -p "$EXPORT_DIR"

# Create tar archive
echo "Packaging $WORKSPACE -> $ARTIFACT"
tar cf "$ARTIFACT" -C "$(dirname "$WORKSPACE")" "$(basename "$WORKSPACE")" 2>/dev/null

if [ $? -ne 0 ]; then
  echo "ERROR: tar failed."
  exit 1
fi

# Write manifest
SIZE=$(stat -c %s "$ARTIFACT" 2>/dev/null || wc -c < "$ARTIFACT" | tr -d ' ')
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date)
cat > "$MANIFEST" <<EOF
{
  "timestamp": "$TIMESTAMP",
  "source": "$WORKSPACE",
  "artifact": "$ARTIFACT",
  "size": $SIZE
}
EOF

echo "Export ready: $ARTIFACT ($SIZE bytes)"
echo "Click 'Save to Disk' in the browser to download."
